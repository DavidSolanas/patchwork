# Required: GitHub PAT for fetching issues, forking, and creating PRs.
# Use a fine-grained token scoped to the repos you intend to contribute to.
# The authenticated user becomes the PR author.
GITHUB_TOKEN=

# Required: Anthropic API key for the Haiku triage step.
ANTHROPIC_API_KEY=

# Required for full runs (not needed for `patchwork triage` or --dry-run).
# Cursor SDK key for cloud agent dispatch.
CURSOR_API_KEY=
