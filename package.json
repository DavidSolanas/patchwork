{
  "name": "patchwork",
  "version": "0.1.0",
  "description": "Autonomous open-source contribution agent built on the Cursor SDK. Human-reviewed PRs only.",
  "type": "module",
  "bin": {
    "patchwork": "./dist/main.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "audit:invariants": "node scripts/invariant-audit.mjs ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@cursor/sdk": "latest",
    "@octokit/plugin-retry": "^7.0.0",
    "@octokit/plugin-throttling": "^9.0.0",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^17.4.2",
    "ora": "^8.0.0",
    "parse-diff": "^0.11.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.15.0",
    "nock": "^14.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "undici": "^7.0.0",
    "tar": "^7.5.11"
  }
}
